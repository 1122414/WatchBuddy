<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/panel_background"
            android:text="@string/status_not_ready"
            android:textColor="@color/text_primary"
            android:textSize="17sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical">

            <EditText
                android:id="@+id/peer_package"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/peer_package_hint"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

            <EditText
                android:id="@+id/peer_fingerprint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/peer_fingerprint_hint"
                android:inputType="textNoSuggestions"
                android:minLines="2"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

            <Button
                android:id="@+id/save_peer_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_secondary"
                android:text="@string/save_peer"
                android:textAllCaps="false"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <Button
            android:id="@+id/authorize_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/button_primary"
            android:text="@string/authorize"
            android:textAllCaps="false"
            android:textColor="@color/accent_text" />

        <Button
            android:id="@+id/refresh_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_secondary"
            android:text="@string/refresh_devices"
            android:textAllCaps="false"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/receiver_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_secondary"
            android:text="@string/register_receiver"
            android:textAllCaps="false"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/send_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_primary"
            android:enabled="false"
            android:text="@string/send_demo"
            android:textAllCaps="false"
            android:textColor="@color/accent_text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/initiative_title"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/quiet_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/quiet_mode"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/initiative_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/initiative_reason_default"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/daily_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_secondary"
                    android:text="@string/send_daily"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary" />

                <Button
                    android:id="@+id/random_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_secondary"
                    android:text="@string/send_random"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <Button
                android:id="@+id/follow_up_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_secondary"
                android:text="@string/send_follow_up"
                android:textAllCaps="false"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/schedule_demo_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_primary"
                android:text="@string/schedule_demo"
                android:textAllCaps="false"
                android:textColor="@color/accent_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_title"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/voice_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/voice_idle"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/voice_transcript"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_primary"
                android:textIsSelectable="true" />

            <Button
                android:id="@+id/voice_start_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/button_primary"
                android:text="@string/voice_start"
                android:textAllCaps="false"
                android:textColor="@color/accent_text" />

            <Button
                android:id="@+id/voice_cancel_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_secondary"
                android:text="@string/voice_cancel"
                android:textAllCaps="false"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/voice_remember_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_secondary"
                android:text="@string/voice_remember"
                android:textAllCaps="false"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_title"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/activity_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/activity_idle"
                android:textColor="@color/text_secondary" />

            <Button
                android:id="@+id/activity_sample_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/button_secondary"
                android:text="@string/activity_sample"
                android:textAllCaps="false"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/activity_nudge_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_secondary"
                android:text="@string/activity_nudge"
                android:textAllCaps="false"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/memory_title"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/memory_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/memory_empty"
                android:textColor="@color/text_secondary" />

            <Button
                android:id="@+id/memory_view_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/button_secondary"
                android:text="@string/memory_view"
                android:textAllCaps="false"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/memory_clear_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_secondary"
                android:text="@string/memory_clear"
                android:textAllCaps="false"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <TextView
            android:id="@+id/log_text"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/panel_background"
            android:fontFamily="monospace"
            android:gravity="bottom"
            android:scrollbars="vertical"
            android:textColor="@color/text_secondary"
            android:textIsSelectable="true"
            android:textSize="13sp" />

        <Button
            android:id="@+id/clear_log_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_secondary"
            android:text="@string/clear_log"
            android:textAllCaps="false"
            android:textColor="@color/text_primary" />
    </LinearLayout>
</ScrollView>
