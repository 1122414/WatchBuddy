<div class="root">
  <div class="container">
    <div class="status-row">
      <text class="status-dot">●</text>
      <text class="pet-name">{{petName}}</text>
      <text class="state-label"> · {{stateLabel}}</text>
    </div>

    <div class="character" onclick="onCharacterTap">
      <image class="pet-frame" src="{{petFramePath}}"></image>
    </div>

    <text class="hint">{{hint}}</text>

    <div class="actions">
      <input class="action" type="button" value="聊聊" onclick="playWave"></input>
      <input class="action primary" type="button" value="鼓励" onclick="playJump"></input>
      <input class="action quiet" type="button" value="晚安" onclick="restPet"></input>
    </div>

    <text class="connection-note">{{connectionLabel}} · AI 回复由 DeepSeek 生成</text>
  </div>
</div>
